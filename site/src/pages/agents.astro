const launchAgents = agents.filter((a) => a.status === "launch");
const comingSoon = agents.filter((a) => a.status === "coming-soon");
---

<Layout>
  <Navbar />
  <main>
    <!-- Header -->
    <section
      class="relative px-6 sm:px-10 pt-40 pb-20 bg-ship-bg overflow-hidden"
    >
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[400px] bg-ship-accent/5 rounded-full blur-[140px] pointer-events-none"
      >
      </div>
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <div
          class="inline-flex items-center gap-2 mb-6 px-3 py-1 rounded-full border border-ship-accent/20 bg-ship-accent/5 font-mono text-[10px] tracking-widest uppercase text-ship-accent/70 font-bold"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-ship-green animate-pulse"
          ></span>
          COMPATIBILITY REGISTRY
        </div>
        <h1
          class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tighter font-display uppercase italic mb-6 text-ship-text"
        >
          Every Agent,<br /><span class="text-ship-accent"
            >One Skill Format.</span
          >
        </h1>
        <p
          class="text-base sm:text-lg font-light text-ship-dim max-w-2xl mx-auto leading-relaxed"
        >
          Ship compiles skills into the exact path and format each agent
          expects. Write once, run anywhere — across {agents.length} agents and counting.
        </p>

        <!-- Stats strip -->
        <div
          class="mt-10 flex flex-wrap items-center justify-center gap-6 sm:gap-10 font-mono text-[10px] uppercase tracking-widest"
        >
          <div class="flex items-center gap-2">
            <span class="text-ship-green font-bold text-lg"
              >{launchAgents.length}</span
            >
            <span class="text-ship-dim/50">At Launch</span>
          </div>
          <div class="w-px h-4 bg-ship-border"></div>
          <div class="flex items-center gap-2">
            <span class="text-ship-dim font-bold text-lg"
              >{comingSoon.length}</span
            >
            <span class="text-ship-dim/50">Coming Soon</span>
          </div>
          <div class="w-px h-4 bg-ship-border"></div>
          <div class="flex items-center gap-2">
            <span class="text-ship-accent font-bold text-lg"
              >{agents.length}</span
            >
            <span class="text-ship-dim/50">Total Planned</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Launch Agents (featured) -->
    <section class="px-6 sm:px-10 pb-16 bg-ship-bg">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <span
            class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-ship-green"
            >Available at Launch</span
          >
          <div class="flex-1 h-px bg-ship-border/40"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {
            launchAgents.map((agent) => (
              <a
                href={agent.link || "#"}
                target="_blank"
                rel="noopener noreferrer"
                class="group block p-6 rounded-2xl border border-ship-green/20 bg-ship-green/5 hover:bg-ship-green/10 hover:border-ship-green/40 transition-all duration-300"
              >
                <div class="flex items-center justify-between mb-4">
                  <h3 class="text-base font-bold tracking-tight font-display text-ship-text group-hover:text-ship-green transition-colors">
                    {agent.name}
                  </h3>
                  <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full border border-ship-green/20 bg-ship-green/10">
                    <span class="w-1.5 h-1.5 rounded-full bg-ship-green animate-pulse" />
                    <span class="font-mono text-[9px] uppercase tracking-widest font-bold text-ship-green">
                      Launch
                    </span>
                  </div>
                </div>
                <div class="space-y-2 font-mono text-[10px]">
                  <div class="flex items-start gap-2">
                    <span class="text-ship-dim/40 shrink-0 w-12">FLAG</span>
                    <span class="text-ship-accent">--{agent.flag}</span>
                  </div>
                  <div class="flex items-start gap-2">
                    <span class="text-ship-dim/40 shrink-0 w-12">LOCAL</span>
                    <span class="text-ship-dim/70 break-all">
                      {agent.projectPath}
                    </span>
                  </div>
                  <div class="flex items-start gap-2">
                    <span class="text-ship-dim/40 shrink-0 w-12">GLOBAL</span>
                    <span class="text-ship-dim/70 break-all">
                      {agent.globalPath}
                    </span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Full directory table -->
    <section class="px-6 sm:px-10 pb-32 bg-ship-bg">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <span
            class="text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-ship-dim/60"
            >Coming Soon — {comingSoon.length} agents</span
          >
          <div class="flex-1 h-px bg-ship-border/40"></div>
        </div>

        <!-- Table -->
        <div
          class="overflow-x-auto rounded-2xl border border-ship-border/50 shadow-2xl"
        >
          <table class="w-full font-mono text-[11px] text-left">
            <thead>
              <tr class="border-b border-ship-border/50 bg-ship-surface/50">
                <th
                  class="px-5 py-4 text-[9px] uppercase tracking-widest text-ship-dim/50 font-bold"
                  >Agent</th
                >
                <th
                  class="px-5 py-4 text-[9px] uppercase tracking-widest text-ship-dim/50 font-bold hidden sm:table-cell"
                  >--flag</th
                >
                <th
                  class="px-5 py-4 text-[9px] uppercase tracking-widest text-ship-dim/50 font-bold hidden md:table-cell"
                  >Project Path</th
                >
                <th
                  class="px-5 py-4 text-[9px] uppercase tracking-widest text-ship-dim/50 font-bold hidden lg:table-cell"
                  >Global Path</th
                >
                <th
                  class="px-5 py-4 text-[9px] uppercase tracking-widest text-ship-dim/50 font-bold"
                  >Status</th
                >
              </tr>
            </thead>
            <tbody>
              {
                comingSoon.map((agent, i) => (
                  <tr
                    class={`border-b border-ship-border/20 hover:bg-ship-surface/50 transition-colors ${i % 2 === 0 ? "bg-ship-bg" : "bg-ship-surface/10"}`}
                  >
                    <td class="px-5 py-3.5 text-ship-text font-bold">
                      {agent.name}
                    </td>
                    <td class="px-5 py-3.5 text-ship-accent/70 hidden sm:table-cell">
                      --{agent.flag}
                    </td>
                    <td class="px-5 py-3.5 text-ship-dim/50 hidden md:table-cell">
                      {agent.projectPath}
                    </td>
                    <td class="px-5 py-3.5 text-ship-dim/40 hidden lg:table-cell">
                      {agent.globalPath}
                    </td>
                    <td class="px-5 py-3.5">
                      <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full border border-ship-border/40 bg-ship-surface text-[9px] uppercase tracking-widest font-bold text-ship-dim/50">
                        <span class="w-1 h-1 rounded-full bg-ship-dim/30" />
                        Soon
                      </span>
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <p
          class="mt-6 text-center font-mono text-[10px] text-ship-dim/30 uppercase tracking-widest"
        >
          All {agents.length} agents share the same skill format — author once, deploy
          everywhere.
        </p>
      </div>
    </section>

    <!-- CTA strip -->
    <section
      class="px-10 py-20 border-t border-ship-border/40 bg-ship-bg text-center"
    >
      <div class="max-w-xl mx-auto">
        <div class="w-12 h-12 mx-auto mb-6">
          <Logo class="w-full h-full" idPrefix="agents-cta" />
        </div>
        <h2
          class="text-2xl sm:text-3xl font-bold tracking-tighter font-display uppercase italic mb-4 text-ship-text"
        >
          Don't see your agent?
        </h2>
        <p class="text-ship-dim font-light mb-8">
          Open an issue on GitHub to request a specific integration, or join the
          alpha to help shape what lands next.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="https://github.com/madvib/Ship/issues"
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 text-sm font-bold text-ship-bg bg-ship-accent rounded-xl hover:opacity-90 hover:-translate-y-0.5 transition-all shadow-lg shadow-ship-accent/10"
          >
            REQUEST AN INTEGRATION
          </a>
          <a
            href="/#waitlist"
            class="px-6 py-3 text-sm font-medium text-ship-dim border border-ship-border rounded-xl hover:bg-ship-surface hover:text-ship-text transition-all"
          >
            JOIN THE ALPHA
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
