---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";

const businessValue = [
  "Compresses planning-to-delivery cycles by keeping every agent in sync with current project context.",
  "Reduces costly rework by enforcing branch-aware intent, policy, and dependency context before generation.",
  "Creates a single operating model for human + AI software teams across tools, repos, and environments.",
];

const platformPlay = [
  "Ship is an SDLC engine: it compiles project intent into runnable agent context for each tool in use.",
  "Branch events trigger deterministic context regeneration, so agent behavior tracks repo state in real time.",
  "A shared runtime powers CLI, MCP, and UI surfaces, forming a portable control plane for agent execution.",
];

const enterpriseVision = [
  "Enterprise teams adopt one governed context layer instead of fragmented per-tool prompt engineering.",
  "Policy, permissions, skills, and change history become auditable system primitives for compliance and trust.",
  "Ship evolves from dev workflow orchestration into the enterprise standard for multi-agent software delivery.",
];
---

<Layout
  title="Ship — Investor Brief"
  description="Investor one-sheet: business value, platform strategy, and enterprise vision."
>
  <main class="min-h-screen bg-ship-bg text-ship-text">
    <section class="px-6 sm:px-10 lg:px-16 pt-16 pb-8 border-b border-ship-border">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-center gap-3 mb-6">
          <Logo class="h-8 w-auto" idPrefix="investors" />
          <p class="text-xs font-mono tracking-[0.22em] text-ship-dim/60 uppercase">
            Investor Brief
          </p>
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-extrabold tracking-tight uppercase italic leading-[0.95]">
          The Operating Layer<br />
          For Agentic Software Delivery
        </h1>

        <p class="mt-6 text-base sm:text-lg text-ship-dim max-w-3xl leading-relaxed">
          Ship turns project intent into deterministic execution context across AI coding agents.
          The result: faster delivery, lower coordination overhead, and a governable path to
          enterprise-scale AI-native software development.
        </p>
      </div>
    </section>

    <section class="px-6 sm:px-10 lg:px-16 py-12">
      <div class="max-w-5xl mx-auto grid gap-8">
        <article class="rounded-2xl border border-ship-border bg-ship-surface/70 p-6 sm:p-8">
          <p class="text-[11px] font-mono tracking-[0.2em] uppercase text-ship-accent/80 mb-3">
            01 / Business Value
          </p>
          <ul class="space-y-4">
            {businessValue.map((item) => (
              <li class="text-ship-dim leading-relaxed flex gap-3">
                <span class="mt-2 h-1.5 w-1.5 rounded-full bg-ship-accent flex-shrink-0"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>

        <article class="rounded-2xl border border-ship-border bg-ship-surface/70 p-6 sm:p-8">
          <p class="text-[11px] font-mono tracking-[0.2em] uppercase text-ship-blue/90 mb-3">
            02 / Engine + Platform Play
          </p>
          <ul class="space-y-4">
            {platformPlay.map((item) => (
              <li class="text-ship-dim leading-relaxed flex gap-3">
                <span class="mt-2 h-1.5 w-1.5 rounded-full bg-ship-blue flex-shrink-0"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>

        <article class="rounded-2xl border border-ship-border bg-ship-surface/70 p-6 sm:p-8">
          <p class="text-[11px] font-mono tracking-[0.2em] uppercase text-ship-green/90 mb-3">
            03 / Enterprise Vision
          </p>
          <ul class="space-y-4">
            {enterpriseVision.map((item) => (
              <li class="text-ship-dim leading-relaxed flex gap-3">
                <span class="mt-2 h-1.5 w-1.5 rounded-full bg-ship-green flex-shrink-0"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      </div>
    </section>
  </main>
</Layout>
