{
  "name": "Ship",
  "image": "ghcr.io/prulloac/base:ubuntu-24.04",

  "features": {
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "1.93.1",
      "profile": "default"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/devcontainers-extra/features/pnpm:2": {},
    "ghcr.io/devcontainers-extra/features/claude-code:1": {},
    "ghcr.io/devcontainers-extra/features/just:1": {}
  },

  "onCreateCommand": "rustup target add wasm32-unknown-unknown && cargo install wasm-pack --locked",
  "postCreateCommand": "pnpm install",

  "mounts": [
    "source=ship-cargo-registry,target=/usr/local/cargo/registry,type=volume",
    "source=ship-cargo-git,target=/usr/local/cargo/git,type=volume",
    "source=ship-target,target=${containerWorkspaceFolder}/target,type=volume"
  ],

  "forwardPorts": [3000, 7701],
  "portsAttributes": {
    "3000": { "label": "Ship Studio", "onAutoForward": "openBrowser" },
    "7701": { "label": "Ship Server", "onAutoForward": "silent" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "oxc.oxc-vscode",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer",
          "editor.formatOnSave": true
        }
      }
    }
  },

  "remoteUser": "vscode"
}
